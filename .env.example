PYTH_HERMES_URL=https://hermes.pyth.network

# Reown (AppKit) configuration
APPKIT_PROJECT_ID=
NUXT_PUBLIC_APP_URL=

# Wallet screening
WALLET_SCREENING_URI=

# API URLs
EULER_API_URL=
SWAP_API_URL=
PRICE_API_URL=

# Tenderly simulation (server-side only, optional)
TENDERLY_ACCESS_KEY=
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=

# Chain configuration
# Enabled chains are derived from RPC_URL_HTTP_<chainId> env vars.
# Each RPC URL also needs a matching NUXT_PUBLIC_SUBGRAPH_URI_<chainId>.
# Any chain ID supported by @reown/appkit/networks works — no code changes needed.
#
# RPC URLs (server-side only, never exposed to client bundle)
RPC_URL_HTTP_1=

# CONFIG_ vars (override via NUXT_PUBLIC_CONFIG_* in Doppler)
NUXT_PUBLIC_CONFIG_DOCS_URL="https://github.com/"
NUXT_PUBLIC_CONFIG_TOS_URL="https://github.com/"
NUXT_PUBLIC_CONFIG_TOS_MD_URL=""
NUXT_PUBLIC_CONFIG_X_URL="https://x.com/"
NUXT_PUBLIC_CONFIG_DISCORD_URL="https://discord.com/"
NUXT_PUBLIC_CONFIG_TELEGRAM_URL="https://t.me/"
NUXT_PUBLIC_CONFIG_GITHUB_URL="https://github.com/"
NUXT_PUBLIC_CONFIG_APP_TITLE="Euler Lite"
NUXT_PUBLIC_CONFIG_APP_DESCRIPTION="Lightweight interface for Euler Finance lending and borrowing."
NUXT_PUBLIC_CONFIG_LABELS_REPO="euler-xyz/euler-labels"
NUXT_PUBLIC_CONFIG_ORACLE_CHECKS_REPO="euler-xyz/oracle-checks"
# Feature flags — all enabled by default. Uncomment and set to "false" to disable:
# NUXT_PUBLIC_CONFIG_ENABLE_TOS_SIGNATURE="false"
# NUXT_PUBLIC_CONFIG_ENABLE_ENTITY_BRANDING="false"
# NUXT_PUBLIC_CONFIG_ENABLE_VAULT_TYPE="false"
# NUXT_PUBLIC_CONFIG_ENABLE_EARN_PAGE="false"
# NUXT_PUBLIC_CONFIG_ENABLE_LEND_PAGE="false"

# Subgraph URIs per chain
NUXT_PUBLIC_SUBGRAPH_URI_1=
NUXT_PUBLIC_SUBGRAPH_URI_42161=

# for dev server only
HTTPS_KEY=/path/to/key.pem
HTTPS_CERT=/path/to/cert.pem
