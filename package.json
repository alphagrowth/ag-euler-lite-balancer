{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "nuxt typecheck",
    "postinstall": "nuxt prepare && simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs,mts}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@floating-ui/vue": "1.1.11",
    "@gvade/nuxt3-svg-sprite": "1.0.3",
    "@nuxt/eslint": "1.0.1",
    "@nuxt/kit": "3.17.4",
    "@pythnetwork/price-service-client": "1.11.0",
    "@reown/appkit": "1.8.19",
    "@reown/appkit-adapter-wagmi": "1.8.19",
    "@tanstack/vue-query": "5.95.2",
    "@vueuse/nuxt": "13.3.0",
    "@wagmi/core": "^2.22.1",
    "@wagmi/vue": "0.5.1",
    "axios": "1.13.6",
    "chart.js": "4.5.1",
    "chartjs-plugin-annotation": "3.1.0",
    "luxon": "3.7.2",
    "modern-normalize": "3.0.1",
    "nuxt": "3.16.1",
    "viem": "2.47.6",
    "vue": "3.5.30",
    "vue-chartjs": "5.3.3",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "6.14.0",
    "@types/luxon": "3.7.1",
    "eslint": "9.39.4",
    "lint-staged": "16.4.0",
    "playwright": "^1.58.2",
    "sass": "1.98.0",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vitest": "^4.1.1",
    "vue-tsc": "2.2.12"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "unhead": ">=2.1.11"
  },
  "license": "MIT"
}
